# ReachBot backend env. For local dev, copy to .env and `set -a; source .env; set +a`.
# In production, set these as Fly.io secrets (`fly secrets set KEY=value`).

# Required — Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Path to the vector index. Local dev points at the repo-root copy; the Docker
# image bakes it in at /app/index.npz.
INDEX_PATH=../index.npz

# Password gate. Leave ACCESS_PASSWORD empty to disable the gate entirely.
# If ACCESS_PASSWORD is set, SESSION_SECRET is REQUIRED (signs the auth cookie).
ACCESS_PASSWORD=
SESSION_SECRET=

# CORS: the frontend origin allowed to call this API.
# Local: http://localhost:3000   Prod: https://<your-vercel-app>.vercel.app
ALLOWED_ORIGIN=http://localhost:3000
